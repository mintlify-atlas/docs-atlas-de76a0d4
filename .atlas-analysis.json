  "keyFeatures": [
    "SQLite-compatible SQL dialect, file format, and C API",
    "Written in Rust for performance and safety",
    "Multi-language bindings: Rust, JavaScript/WASM, Python, Go, Java",
    "Asynchronous I/O with io_uring support on Linux",
    "Vector search with multiple distance metrics (cosine, L2, dot product, Jaccard)",
    "Full-text search powered by Tantivy",
    "Change Data Capture (CDC) for real-time change tracking",
    "MVCC (Multi-Version Concurrency Control) for concurrent transactions",
    "Encryption at rest (experimental)",
    "Built-in MCP server for AI assistant integration",
    "Cross-platform: Linux, macOS, Windows, WebAssembly/browsers"
  ],
  "publicApiSurface": [
    "tursodb (CLI shell)",
    "Builder::new_local() / Builder::new_memory() (Rust API)",
    "db.connect() -> Connection (Rust API)",
    "conn.query(sql, params) (Rust API)",
    "connect(path) -> Database (JavaScript API)",
    "db.prepare(sql) -> Statement (JavaScript API)",
    "stmt.get() / stmt.all() / stmt.run() (JavaScript API)",
    "turso.connect(path) (Python API)",
    "con.cursor() -> Cursor (Python API)",
    "cur.execute(sql) (Python API)",
    "sql.Open('turso', path) (Go API via database/sql)",
    "sqlite3_open / sqlite3_prepare / sqlite3_step (C API)",
    "vector32() / vector64() / vector_distance_cos() / vector_distance_l2() (SQL vector functions)",
    "fts_match() / fts_score() / fts_highlight() (SQL FTS functions)",
    "PRAGMA capture_data_changes_conn() (CDC)",
    "PRAGMA journal_mode (WAL / MVCC mode switching)"
  ]
